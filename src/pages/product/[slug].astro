---
import Image from "astro/components/Image.astro";
import Button from "../../components/Button.astro";
import { getCategoryById } from "../../db/repositories/categories";
import { getActiveProducts } from "../../db/repositories/products";
import { getVariationsByProductId } from "../../db/repositories/variations";
import PublicLayout from "../../layouts/PublicLayout.astro";
import { ASSETS_BASE_URL } from "../../lib/constants";

export const prerender = true;

export async function getStaticPaths() {
	const products = await getActiveProducts();

	return await Promise.all(
		products.map(async (product) => {
			const variations = await getVariationsByProductId(product.id);
			return {
				params: { slug: product.slug },
				props: { product, variations },
			};
		}),
	);
}

const { product, variations: rawVariations } = Astro.props;
// Display largest weight first
const variations = [...rawVariations].reverse();
const category = product.categoryId
	? await getCategoryById(product.categoryId)
	: null;

// Helper function to get the correct image URL
const getImageUrl = (url: string | null) => {
	if (!url) return null;
	return url.startsWith("http://") || url.startsWith("https://")
		? url
		: `${ASSETS_BASE_URL}/${url}`;
};

const imageArray = Array.isArray(product.images) ? product.images : [];
const productImages = imageArray
	.map(getImageUrl)
	.filter((url): url is string => url !== null);
---

<PublicLayout 
  title={product.name}
  description={product.description}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-indigo-600">Главная</a>
      {category && (
        <>
          <span class="mx-2">/</span>
          <a href={`/categories/${category.slug}`} class="hover:text-indigo-600">
            {category.name}
          </a>
        </>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-900">{product.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        {productImages && productImages.length > 0 ? (
          <div class="space-y-4">
            <div class="aspect-square bg-gray-200 rounded-lg overflow-hidden" data-main-image-container>
              <div transition:name={`product-image-${product.slug}`}>
                <Image
                  src={productImages[0]}
                  alt={product.name}
                  width={800}
                  height={800}
                  class="w-full h-full object-cover"
                  data-image-index="0"
                />
              </div>
            </div>
            {productImages.length > 1 && (
              <div class="grid grid-cols-4 gap-4">
                {productImages.slice(1, 5).map((image, index) => (
                  <div class="aspect-square bg-gray-200 rounded-lg overflow-hidden" data-thumbnail data-index={index + 1}>
                    <Image
                      src={image}
                      alt={product.name}
                      width={200}
                      height={200}
                      class="w-full h-full object-cover cursor-pointer hover:opacity-75 transition"
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="aspect-square bg-gray-200 rounded-lg flex items-center justify-center">
            <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        )}
      </div>

      <div>
        <div class="mb-6">
          {category && (
            <a 
              href={`/categories/${category.slug}`}
              class="text-sm text-indigo-600 hover:text-indigo-700 font-medium"
            >
              {category.name}
            </a>
          )}
          <h1 class="text-4xl font-bold text-gray-900 mt-2 mb-2" transition:name={`product-name-${product.slug}`}>
            {product.name}
          </h1>
          {variations.length > 0 ? (
            <div class="mb-6">
              <p id="selected-price" class="text-3xl font-bold text-indigo-600 mb-4" transition:name={`product-price-${product.slug}`}>
                {variations[0].price} &#8381;
              </p>
              <p class="text-sm text-gray-500 mb-3">Выберите вес:</p>
              <div class="flex flex-wrap gap-2" id="variation-buttons">
                {variations.map((v, i) => (
                  <button
                    type="button"
                    class="variation-btn"
                    data-selected={i === 0 ? "true" : "false"}
                    data-variation-id={v.id}
                    data-price={v.price}
                    data-weight={v.weight}
                    data-sku={v.sku}
                  >
                    {v.weight} г
                  </button>
                ))}
              </div>
            </div>
          ) : (
            <p class="text-3xl font-bold text-indigo-600 mb-6" transition:name={`product-price-${product.slug}`}>
              {product.price} &#8381;
            </p>
          )}

          <div class="prose prose-gray mb-8">
            <p>
              {product.description}
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <Button
              id="add-to-cart"
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-price={variations.length > 0 ? variations[0].price : product.price}
              data-product-slug={product.slug}
              data-variation-id={variations.length > 0 ? variations[0].id : undefined}
              data-variation-weight={variations.length > 0 ? variations[0].weight : undefined}
              variant="primary"
            >
              Добавить в корзину
            </Button>
          </div>
        </div>
      </div>

    </div>
  </div>
</PublicLayout>


<script>
	function selectVariationBtn(btn: Element, buttons: NodeListOf<Element>, priceDisplay: HTMLElement | null, addToCartBtn: HTMLElement | null) {
		buttons.forEach((b) => {
			(b as HTMLElement).dataset.selected = 'false';
		});
		(btn as HTMLElement).dataset.selected = 'true';

		const price = (btn as HTMLElement).dataset.price;
		if (priceDisplay && price) {
			priceDisplay.textContent = `${price} \u20BD`;
		}

		if (addToCartBtn) {
			const el = btn as HTMLElement;
			addToCartBtn.setAttribute('data-product-price', el.dataset.price || '');
			addToCartBtn.setAttribute('data-variation-id', el.dataset.variationId || '');
			addToCartBtn.setAttribute('data-variation-weight', el.dataset.weight || '');
		}
	}

	function initVariationSelector() {
		const container = document.getElementById('variation-buttons');
		if (!container) return;
		const buttons = container.querySelectorAll('.variation-btn');
		const priceDisplay = document.getElementById('selected-price');
		const addToCartBtn = document.getElementById('add-to-cart');
		if (!buttons.length) return;

		const syncWeightToUrl = (weight: string) => {
			const url = new URL(window.location.href);
			if (url.searchParams.get('weight') !== weight) {
				url.searchParams.set('weight', weight);
				history.replaceState(null, '', url.toString());
			}
		};

		// Restore selection from URL or ensure default is reflected
		const preselectedWeight = new URLSearchParams(window.location.search).get('weight');
		const targetBtn = preselectedWeight
			? Array.from(buttons).find((b) => (b as HTMLElement).dataset.weight === preselectedWeight)
			: null;

		if (targetBtn) {
			selectVariationBtn(targetBtn, buttons, priceDisplay, addToCartBtn);
		}

		// Always reflect the active variation in the URL
		const activeBtn = container.querySelector('.variation-btn[data-selected="true"]') as HTMLElement | null;
		if (activeBtn?.dataset.weight) {
			syncWeightToUrl(activeBtn.dataset.weight);
		}

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				selectVariationBtn(btn, buttons, priceDisplay, addToCartBtn);
				const weight = (btn as HTMLElement).dataset.weight;
				if (weight) syncWeightToUrl(weight);
			});
		});
	}

	function initAddToCart() {
		const addToCartBtn = document.getElementById('add-to-cart');
		if (!addToCartBtn) return;

		addToCartBtn.addEventListener('click', () => {
			const productId = addToCartBtn.getAttribute('data-product-id');
			const productName = addToCartBtn.getAttribute('data-product-name');
			const productPrice = parseFloat(addToCartBtn.getAttribute('data-product-price') || '0');
			const productSlug = addToCartBtn.getAttribute('data-product-slug');
			const variationId = addToCartBtn.getAttribute('data-variation-id') || null;
			const variationWeight = addToCartBtn.getAttribute('data-variation-weight') || null;

			// Cart key: productId + variationId to allow same product with different weights
			const cartKey = variationId ? `${productId}-v${variationId}` : `${productId}`;

			const cart = JSON.parse(localStorage.getItem('cart') || '[]');
			const existingItem = cart.find((item: any) => item.id === cartKey);

			if (existingItem) {
				existingItem.quantity += 1;
			} else {
				cart.push({
					id: cartKey,
					productId: parseInt(productId || '0'),
					name: variationWeight
						? `${productName} (${variationWeight} г)`
						: productName,
					price: productPrice,
					slug: productSlug,
					variationId: variationId ? parseInt(variationId) : null,
					weight: variationWeight ? parseInt(variationWeight) : null,
					quantity: 1,
				});
			}

			localStorage.setItem('cart', JSON.stringify(cart));

			// Update cart count in header
			const cartCount = document.getElementById('cart-count');
			const totalItems = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
			if (cartCount) {
				cartCount.textContent = totalItems.toString();
				cartCount.classList.remove('hidden');
			}

			// Visual feedback
			const originalText = addToCartBtn.textContent;
			addToCartBtn.textContent = 'Добавлено';
			setTimeout(() => {
				addToCartBtn.textContent = originalText;
			}, 1500);
		});
	}

	function initProductDetailPage() {
		initVariationSelector();
		initAddToCart();

		const mainImageContainer = document.querySelector('[data-main-image-container]');
		if (!mainImageContainer) return;
		
		const slug = window.location.pathname.split('/').pop();
		if (!slug) return;
		
		// Check if user navigated from a hovered state
		const storedImageIndex = sessionStorage.getItem(`rublevsky:imgIndex:${slug}`);
		if (storedImageIndex === '1') {
			// User hovered the second image on the product card
			const mainImageDiv = mainImageContainer.querySelector('[data-image-index="0"]')?.parentElement;
			if (mainImageDiv) {
				// Find if there's a second image to show
				const thumbnails = document.querySelectorAll('[data-thumbnail]');
				if (thumbnails.length > 0) {
					const firstThumbnail = thumbnails[0] as HTMLElement;
					const thumbnailImg = firstThumbnail.querySelector('img');
					const mainImg = mainImageDiv.querySelector('img');
					
					if (thumbnailImg && mainImg && thumbnailImg.src) {
						// Swap the main image with the second image
						const tempSrc = mainImg.src;
						mainImg.src = thumbnailImg.src;
						mainImg.srcset = thumbnailImg.srcset || '';
					}
				}
			}
			
			// Clean up the session storage
			sessionStorage.removeItem(`rublevsky:imgIndex:${slug}`);
		}
	}
	
	// Run on page load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initProductDetailPage);
	} else {
		initProductDetailPage();
	}
	
	// Re-run after view transitions
	document.addEventListener('astro:page-load', initProductDetailPage);
</script>
