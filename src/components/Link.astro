---
interface Props {
	href: string;
	class?: string;
	disableAnimation?: boolean;
	prefetch?: boolean;
	[key: string]: unknown;
}

const {
	href,
	class: className,
	disableAnimation = false,
	prefetch = true,
	...rest
} = Astro.props;
const classes =
	`link group ${!disableAnimation ? "link-animated" : ""} ${className || ""}`.trim();

// Only enable prefetch for internal links
const shouldPrefetch = prefetch && href.startsWith("/");
---

<a href={href} class={classes} data-astro-prefetch={shouldPrefetch ? true : undefined} {...rest}>
    {!disableAnimation ? (
        <span class="link-text-wrapper relative inline-block transition-colors duration-(--transition-standard-duration) ease-(--transition-standard-easing) group-hover:text-(--accent) group-active:text-(--accent) group-focus:text-(--accent)">
            <span class="link-text transition-colors duration-(--transition-standard-duration) ease-(--transition-standard-easing) group-hover:text-(--accent) group-active:text-(--accent) group-focus:text-(--accent)">
                <slot />
            </span>
        </span>
    ) : (
        <span class="link-text transition-colors duration-(--transition-standard-duration) ease-(--transition-standard-easing)">
            <slot />
        </span>
    )}
</a>

<style>
    /* Ensure color inheritance for nested elements */
    .link-text-wrapper,
    .link-text {
        color: inherit;
    }
    
    .link .link-text,
    .link .link-text * {
        color: inherit;
    }

    /* THE ANIMATED UNDERLINE - Complex pseudo-element animation requiring custom CSS */
    .link-text-wrapper::before {
        content: "";
        position: absolute;
        display: block;
        width: 100%;
        height: 0.1em;
        bottom: -0.01em;
        left: 0;
        background-color: currentColor;
        transform: scaleX(0);
        transform-origin: center;
        transition: var(--transition-standard);
        backface-visibility: hidden;
        will-change: transform;
    }

    /* Desktop hover states - Animate underline */
    @media (hover: hover) {
        .link-animated {
           
            text-decoration: none;
            &:active {
                transform: scale(0.96);
                transition: transform 0.2s ease-out;
            }
        }
        
        .link:hover .link-text-wrapper::before,
        .link:active .link-text-wrapper::before,
        .link:focus .link-text-wrapper::before {
            transform: scaleX(1);
           
        }
    }

    /* Mobile/touch devices - Static underline fallback */
    @media (hover: none) {
        .link-animated .link-text-wrapper {
            text-decoration: underline;
        }
        
        .link-animated .link-text-wrapper::before {
            display: none;
        }
        
        .link-animated:active .link-text {
            color: var(--accent);
        }
    }
</style>