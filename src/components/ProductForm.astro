---
import type { Category, Product } from "../db/schema";
import Checkbox from "././Checkbox.astro";
import { Dropzone } from "./dropzone";
import Input from "./Input.astro";
import Label from "./input/Label.astro";

interface Props {
	product?: Product;
	categories: Category[];
	mode: "create" | "edit";
}

const { product, categories, mode } = Astro.props;
---

<form id="product-form" class="w-full mx-auto max-w-6xl space-y-6" data-mode={mode} data-product-id={product?.id} novalidate>
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
		<!-- Left: Images -->
		<div>
			<Dropzone
				id="images"
				name="images"
				multiple
				accept="image/*"
				initialImages={product?.images ? (Array.isArray(product.images) ? product.images.join(", ") : product.images) : ""}
				productId={product?.id}
			/>
		</div>

		<!-- Right: General info -->
		<div class="space-y-6">
			<div class="space-y-2">
				<Input
					label="Название"
					type="text"
					id="name"
					name="name"
					value={product?.name || ""}
					required
				/>
			</div>

			<div class="space-y-2">
				<div class="flex items-center justify-between mb-2">
					<Label for="slug">Ярлык (ссылка)</Label>
					<div class="flex items-center gap-2">
						<Checkbox
							label="Авто-генерация"
							id="auto-slug-toggle"
							size="sm"
							variant="secondary"
							checked={true}
						/>
					</div>
				</div>
				<Input
					type="text"
					id="slug"
					name="slug"
					value={product?.slug || ""}
					required
				/>
			</div>

			<div class="space-y-2 pb-2">
				<label for="description" class="text-sm font-medium text-foreground">Описание</label>
				<div class="tiptap-wrapper rounded-md border border-input shadow-xs focus-within:border-outline focus-within:ring-3 focus-within:ring-outline/50 transition-[color,box-shadow]">
					<div id="tiptap-toolbar" class="flex flex-wrap gap-1 border-b border-input px-2 py-1.5 bg-muted/30 rounded-t-md">
						<button type="button" data-action="bold" class="tiptap-btn" title="Жирный">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
						</button>
						<button type="button" data-action="italic" class="tiptap-btn" title="Курсив">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
						</button>
						<button type="button" data-action="strike" class="tiptap-btn" title="Зачёркнутый">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4H9a3 3 0 0 0-2.83 4"/><path d="M14 12a4 4 0 0 1 0 8H6"/><line x1="4" y1="12" x2="20" y2="12"/></svg>
						</button>
						<div class="w-px bg-input mx-1 self-stretch"></div>
						<button type="button" data-action="heading" data-level="2" class="tiptap-btn" title="Заголовок 2">H2</button>
						<button type="button" data-action="heading" data-level="3" class="tiptap-btn" title="Заголовок 3">H3</button>
						<div class="w-px bg-input mx-1 self-stretch"></div>
						<button type="button" data-action="bulletList" class="tiptap-btn" title="Маркированный список">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
						</button>
						<button type="button" data-action="orderedList" class="tiptap-btn" title="Нумерованный список">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>
						</button>
						<div class="w-px bg-input mx-1 self-stretch"></div>
						<button type="button" data-action="blockquote" class="tiptap-btn" title="Цитата">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3z"/></svg>
						</button>
						<button type="button" data-action="horizontalRule" class="tiptap-btn" title="Разделитель">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="12" x2="22" y2="12"/></svg>
						</button>
						<div class="w-px bg-input mx-1 self-stretch"></div>
						<button type="button" data-action="link" class="tiptap-btn" title="Ссылка (Ctrl+K)">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
						</button>
					</div>
					<div id="tiptap-editor" class="px-3 py-2 min-h-[120px] max-h-[400px] overflow-y-auto"></div>
				</div>
				<input type="hidden" id="description" name="description" value={product?.description || ""} />
				<span data-error-for="description" class="text-xs font-medium text-error hidden"></span>
			</div>

			<div class="grid grid-cols-2 gap-4">
				<div class="space-y-2">
					<Input
						label="Цена за 100 г ₽"
						type="number"
						id="price"
						name="price"
						step="1"
						min="0"
						value={product?.price?.toString() || ""}
						required
					/>
				</div>
				<div class="space-y-2">
					<Input
						label="Объём г"
						type="number"
						id="volume"
						name="volume"
						min="0"
						value={product?.volume?.toString() || "0"}
						step="1"
						required
					/>
				</div>
			</div>

			<div class="space-y-2">
				<Checkbox
					label="Малый объём дороже за грамм"
					id="priceUp"
					name="priceUp"
					checked={product?.priceUp !== false}
					size="sm"
					variant="secondary"
				/>
			</div>

			<!-- Variations preview -->
			<div id="variations-preview" class="hidden">
				<Label for="variations-preview">Вариации</Label>
				<div id="variations-list" class="mt-2 rounded-lg border border-gray-200 overflow-hidden">
					<table class="w-full text-sm">
						<thead >
							<tr>
								<th class="px-3 py-2 text-left font-medium text-gray-600">Вес</th>
								<th class="px-3 py-2 text-right font-medium text-gray-600">Цена</th>
								<th class="px-3 py-2 text-right font-medium text-gray-600">&#8381;/г</th>
							</tr>
						</thead>
						<tbody id="variations-tbody"></tbody>
					</table>
				</div>
			</div>

			<div class="space-y-2">
				<Label for="categoryId">Категория</Label>
				<select
					id="categoryId"
					name="categoryId"
					class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
				>
					<option value="">Выберите категорию</option>
					{
						categories.map((category) => (
							<option
								value={category.id}
								selected={product?.categoryId === category.id}
							>
								{category.name}
							</option>
						))
					}
				</select>
			</div>

			<div class="space-y-2">
				<Checkbox
					label="Активен"
					id="isActive"
					name="isActive"
					checked={product?.isActive !== false}
					class="mr-2"
				/>
			</div>
		</div>
	</div>

</form>

<script>
	import { Editor } from "@tiptap/core";
import Link from "@tiptap/extension-link";
import StarterKit from "@tiptap/starter-kit";
import { navigate } from "astro:transitions/client";
import { generateWeightSteps, getSmallQuantityMultiplier } from "../lib/variations";

	type Level = 1 | 2 | 3 | 4 | 5 | 6;

	// Transliteration map for Russian to English
	const CYRILLIC_TO_LATIN: Record<string, string> = {
		а: "a", б: "b", в: "v", г: "g", д: "d", е: "e", ё: "yo", ж: "zh",
		з: "z", и: "i", й: "y", к: "k", л: "l", м: "m", н: "n", о: "o",
		п: "p", р: "r", с: "s", т: "t", у: "u", ф: "f", х: "kh", ц: "ts",
		ч: "ch", ш: "sh", щ: "shch", ъ: "", ы: "y", ь: "", э: "e", ю: "yu", я: "ya",
	};

	// Generate URL-friendly slug from text with Cyrillic support
	function generateSlug(text: string): string {
		return text
			.toLowerCase()
			.split("")
			.map((char) => CYRILLIC_TO_LATIN[char] ?? char)
			.join("")
			.replace(/[^\w\s-]/g, "")
			.replace(/\s+/g, "-")
			.replace(/-+/g, "-")
			.replace(/^-|-$/g, "");
	}

	function generateVariationsPreview(pricePer100g: number, totalWeight: number, smallerCostsMore: boolean) {
		const steps = generateWeightSteps(totalWeight);
		const basePricePerGram = pricePer100g / 100;
		const maxWeight = steps[steps.length - 1];
		return steps.map((weight) => {
			let ppg = basePricePerGram;
			if (smallerCostsMore && weight < maxWeight) ppg *= getSmallQuantityMultiplier(weight);
			return { weight, price: Math.round(ppg * weight), pricePerGram: ppg };
		});
	}

	function init(): Editor | null {
		const form = document.getElementById("product-form") as HTMLFormElement | null;
		if (!form) return null;

		const mode = form.dataset.mode as "create" | "edit" | undefined;
		const productId = form.dataset.productId ? parseInt(form.dataset.productId, 10) : undefined;

		const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
		const imageUploadContainer = document.querySelector(".image-upload-container") as (HTMLElement & { _imageUploadHandler?: any }) | null;
		const deleteBtn = document.getElementById("delete-btn") as HTMLButtonElement | null;

		const submitOriginalLabel = submitBtn?.querySelector<HTMLElement>(".btn-label")?.textContent?.trim() ?? "";
		const deleteOriginalLabel = deleteBtn?.querySelector<HTMLElement>(".btn-label")?.textContent?.trim() ?? "";

		// --- Tiptap Editor ---
		const editorElement = document.getElementById("tiptap-editor");
		const descriptionInput = document.getElementById("description") as HTMLInputElement | null;
		let editor: Editor | null = null;

		if (editorElement && descriptionInput) {
			editor = new Editor({
				element: editorElement,
				extensions: [
					StarterKit,
					Link.configure({
						openOnClick: false,
						defaultProtocol: "https",
						HTMLAttributes: {
							rel: "noopener noreferrer nofollow",
							target: "_blank",
						},
					}),
				],
				content: descriptionInput.value || "",
				editorProps: {
					attributes: {
						class: "outline-none min-h-[100px]",
					},
				},
				onUpdate({ editor: ed }) {
					descriptionInput.value = ed.isEmpty ? "" : ed.getHTML();
					clearError("description");
				},
			});

			// Toolbar buttons
			const toolbar = document.getElementById("tiptap-toolbar");
			toolbar?.addEventListener("click", (e) => {
				const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-action]");
				if (!btn || !editor) return;

				const action = btn.dataset.action!;
				switch (action) {
					case "bold":
						editor.chain().focus().toggleBold().run();
						break;
					case "italic":
						editor.chain().focus().toggleItalic().run();
						break;
					case "strike":
						editor.chain().focus().toggleStrike().run();
						break;
					case "heading":
						editor.chain().focus().toggleHeading({ level: parseInt(btn.dataset.level!) as Level }).run();
						break;
					case "bulletList":
						editor.chain().focus().toggleBulletList().run();
						break;
					case "orderedList":
						editor.chain().focus().toggleOrderedList().run();
						break;
					case "blockquote":
						editor.chain().focus().toggleBlockquote().run();
						break;
					case "horizontalRule":
						editor.chain().focus().setHorizontalRule().run();
						break;
					case "link":
						toggleLinkPrompt();
						return;
				}
				updateToolbarState();
			});

			// Update active state on toolbar buttons
			function updateToolbarState() {
				if (!editor || !toolbar) return;
				toolbar.querySelectorAll<HTMLButtonElement>("[data-action]").forEach((btn) => {
					const action = btn.dataset.action!;
					let isActive = false;
					switch (action) {
						case "bold": isActive = editor!.isActive("bold"); break;
						case "italic": isActive = editor!.isActive("italic"); break;
						case "strike": isActive = editor!.isActive("strike"); break;
						case "heading": isActive = editor!.isActive("heading", { level: parseInt(btn.dataset.level!) }); break;
						case "bulletList": isActive = editor!.isActive("bulletList"); break;
						case "orderedList": isActive = editor!.isActive("orderedList"); break;
						case "blockquote": isActive = editor!.isActive("blockquote"); break;
						case "link": isActive = editor!.isActive("link"); break;
					}
					btn.classList.toggle("is-active", isActive);
				});
			}

			function toggleLinkPrompt() {
				if (!editor) return;
				if (editor.isActive("link")) {
					editor.chain().focus().unsetLink().run();
					updateToolbarState();
					return;
				}
				const href = window.prompt("URL ссылки:", "https://");
				if (!href || href === "https://") return;
				editor.chain().focus().setLink({ href }).run();
				updateToolbarState();
			}

			editor.on("selectionUpdate", updateToolbarState);
			editor.on("update", updateToolbarState);
		}

		// Slug auto-generation setup
		const nameInput = document.getElementById("name") as HTMLInputElement | null;
		const slugInput = document.getElementById("slug") as HTMLInputElement | null;
		const autoSlugToggle = document.getElementById("auto-slug-toggle") as HTMLInputElement | null;

		// Set initial state: auto-slug ON by default for both create and edit modes
		let isAutoSlug = true;

		// Update slug input visual state based on auto-generation toggle
		function updateSlugInputState() {
			if (!slugInput) return;
			if (isAutoSlug) {
				slugInput.readOnly = true;
				slugInput.classList.add("cursor-not-allowed", "opacity-50");
			} else {
				slugInput.readOnly = false;
				slugInput.classList.remove("cursor-not-allowed", "opacity-50");
			}
		}

		if (autoSlugToggle && slugInput) {
			autoSlugToggle.checked = isAutoSlug;
			updateSlugInputState();
		}

		// Auto-generate slug from name when typing
		nameInput?.addEventListener("input", (e) => {
			if (isAutoSlug && slugInput) {
				slugInput.value = generateSlug((e.target as HTMLInputElement).value);
			}
		});

		// Toggle auto-generation on/off
		autoSlugToggle?.addEventListener("change", (e) => {
			isAutoSlug = (e.target as HTMLInputElement).checked;
			updateSlugInputState();
			if (isAutoSlug && nameInput && slugInput) {
				slugInput.value = generateSlug(nameInput.value);
			}
		});

		// --- Variations preview ---
		const priceInput = document.getElementById("price") as HTMLInputElement | null;
		const volumeInput = document.getElementById("volume") as HTMLInputElement | null;
		const smallerQtyCheckbox = document.getElementById("priceUp") as HTMLInputElement | null;
		const variationsPreview = document.getElementById("variations-preview");
		const variationsTbody = document.getElementById("variations-tbody");

		function updateVariationsPreview() {
			if (!priceInput || !volumeInput || !variationsPreview || !variationsTbody) return;

			const price = parseFloat(priceInput.value);
			const volume = parseInt(volumeInput.value, 10);
			const smallerCostsMore = smallerQtyCheckbox?.checked ?? true;

			if (!price || price <= 0 || !volume || volume <= 0) {
				variationsPreview.classList.add("hidden");
				return;
			}

			const variations = generateVariationsPreview(price, volume, smallerCostsMore);

			if (variations.length === 0) {
				variationsPreview.classList.add("hidden");
				return;
			}

			variationsPreview.classList.remove("hidden");
			variationsTbody.innerHTML = '';
			for (const v of variations) {
				const tr = document.createElement('tr');
				tr.className = 'border-t border-gray-100';
				const tdWeight = document.createElement('td');
				tdWeight.className = 'px-3 py-1.5 text-gray-800';
				tdWeight.textContent = `${v.weight} г`;
				const tdPrice = document.createElement('td');
				tdPrice.className = 'px-3 py-1.5 text-right text-gray-800';
				tdPrice.textContent = `${v.price} \u20BD`;
				const tdPpg = document.createElement('td');
				tdPpg.className = 'px-3 py-1.5 text-right text-gray-500';
				tdPpg.textContent = v.pricePerGram.toFixed(2);
				tr.append(tdWeight, tdPrice, tdPpg);
				variationsTbody.appendChild(tr);
			}
		}

		priceInput?.addEventListener("input", updateVariationsPreview);
		volumeInput?.addEventListener("input", updateVariationsPreview);
		smallerQtyCheckbox?.addEventListener("change", updateVariationsPreview);

		// Generate preview on load if values exist
		updateVariationsPreview();

		// --- Validation ---
		function showError(inputId: string, message: string) {
			const el = document.querySelector(`[data-error-for="${inputId}"]`);
			if (el) {
				el.textContent = message;
				el.classList.remove("hidden");
			}
		}

		function clearError(inputId: string) {
			const el = document.querySelector(`[data-error-for="${inputId}"]`);
			if (el) {
				el.textContent = "";
				el.classList.add("hidden");
			}
		}

		function validateField(id: string): boolean {
			const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
			if (!el) return true;

			// For description, check editor emptiness
			if (id === "description" && editor) {
				if (editor.isEmpty) {
					showError(id, "Обязательное поле");
					return false;
				}
				clearError(id);
				return true;
			}

			const value = el.value.trim();
			if (!value) {
				showError(id, "Обязательное поле");
				return false;
			}
			if (id === "price") {
				const num = parseFloat(value);
				if (isNaN(num) || num < 0) {
					showError(id, "Введите корректную цену");
					return false;
				}
			}
			if (id === "volume") {
				const num = parseInt(value, 10);
				if (isNaN(num) || num < 0) {
					showError(id, "Введите корректный объём");
					return false;
				}
			}
			clearError(id);
			return true;
		}

		function validateAll(): boolean {
			const fields = ["name", "slug", "description", "price", "volume"];
			return fields.map(validateField).every(Boolean);
		}

		// Clear errors on input
		["name", "slug", "price", "volume"].forEach((id) => {
			document.getElementById(id)?.addEventListener("input", () => clearError(id));
			document.getElementById(id)?.addEventListener("blur", () => validateField(id));
		});

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			if (!submitBtn) return;

			if (!validateAll()) return;

			(submitBtn as any).setState( "loading");

			try {
				const formData = new FormData(form);

				// Get current images from Dropzone
				const imageUploadHandler = imageUploadContainer?._imageUploadHandler;
				if (!imageUploadHandler) {
					throw new Error("Image upload handler not initialized");
				}
				const finalImages = imageUploadHandler.getImages();

				const productData = {
					name: formData.get("name"),
					slug: (slugInput?.value ?? (formData.get("slug") as string)).trim(),
					description: formData.get("description"),
					price: parseFloat(formData.get("price") as string),
					volume: parseInt(formData.get("volume") as string, 10),
					categoryId: formData.get("categoryId")
						? parseInt(formData.get("categoryId") as string, 10)
						: null,
					isActive: formData.get("isActive") === "on",
					priceUp: smallerQtyCheckbox?.checked ?? true,
					images: finalImages,
				};

				const url =
					mode === "create"
						? "/api/admin/products"
						: `/api/admin/products/${productId}`;
				const method = mode === "create" ? "POST" : "PUT";

				console.log("Submitting product data:", productData);

				const response = await fetch(url, {
					method,
					credentials: "same-origin",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(productData),
				});

				if (!response.ok) {
					const errorBody = await response.text();
					console.error("Server response:", response.status, errorBody);
					throw new Error(`Failed to save product: ${response.status} ${errorBody}`);
				}

				(submitBtn as any).setState( "success", "Сохранено");

				setTimeout(() => {
					navigate("/admin/products");
				}, 300);
			} catch (error) {
				console.error("Error:", error);
				(submitBtn as any).setState( "error", "Ошибка");

				setTimeout(() => {
					(submitBtn as any).setState( "", submitOriginalLabel);
				}, 2000);
			}
		});

		deleteBtn?.addEventListener("click", async () => {
			if (!deleteBtn) return;

			(deleteBtn as any).setState( "loading");

			try {
				const response = await fetch(`/api/admin/products/${productId}`, {
					method: "DELETE",
					credentials: "same-origin",
				});

				if (!response.ok) {
					throw new Error("Failed to delete product");
				}

				(deleteBtn as any).setState( "success", "Удалено");

				setTimeout(() => {
					navigate("/admin/products");
				}, 900);
			} catch (error) {
				console.error("Error:", error);
				(deleteBtn as any).setState( "error", "Ошибка");

				setTimeout(() => {
					(deleteBtn as any).setState( "", deleteOriginalLabel);
				}, 2000);
			}
		});

		return editor;
	}

	// Destroy previous editor on page transition
	let currentEditor: Editor | null = null;
	document.addEventListener("astro:before-preparation", () => {
		currentEditor?.destroy();
		currentEditor = null;
	});
	document.addEventListener("astro:page-load", () => {
		currentEditor?.destroy();
		currentEditor = null;
		const ed = init();
		if (ed) currentEditor = ed;
	});
</script>
