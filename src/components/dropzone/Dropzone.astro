		border-color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.05);
	}

	.image-filename {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: 0.75rem;
		line-height: 1rem;
		color: color-mix(in oklch, var(--muted-foreground) 65%, transparent);
	}

	.image-filesize {
		margin-top: 0.125rem;
		font-size: 0.75rem;
		line-height: 1rem;
		color: color-mix(in oklch, var(--muted-foreground) 65%, transparent);
	}

	[data-image-item] img {
		pointer-events: none;
	}

	[data-image-item] .js-remove-image {
		pointer-events: auto;
	}

	.upload-overlay {
		transition: opacity 0.4s ease-out;
	}

	.upload-overlay-fadeout {
		opacity: 0;
	}
</style>
