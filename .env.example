# Database
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Authentication
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
# BETTER_AUTH_URL: localhost for local dev only. Production uses gateway URL (set by deploy script).
BETTER_AUTH_URL=http://localhost:4321

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (ADMIN_EMAIL used as sender address and notification recipient)
RESEND_API_KEY=re_your_api_key
ADMIN_EMAIL=admin@example.com

# Admin access (comma-separated list of emails allowed to access /admin)
ADMIN_EMAILS=admin@example.com

# Image Storage (required for deployment)
YANDEX_STORAGE_BUCKET=your-bucket-name
YANDEX_STORAGE_ACCESS_KEY=your-access-key
YANDEX_STORAGE_SECRET_KEY=your-secret-key
YANDEX_STORAGE_REGION=ru-central1

# Yandex Cloud Configuration (for deployment)
YC_LOCKBOX_SECRET_ID=your-lockbox-secret-id
YC_SERVICE_ACCOUNT_ID=your-service-account-id
YC_FOLDER_ID=your-folder-id

# Deployment Pipeline (for dashboard deploy button)
GITHUB_REPO=your-username/ansin
GITHUB_PAT=ghp_your-personal-access-token
DEPLOY_SECRET=your-shared-secret-for-deploy-callbacks
