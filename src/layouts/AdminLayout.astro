<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} Ансин — админка</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-100">
    <main class="flex-1 overflow-y-auto">
      <div class="p-6">
        <slot />
      </div>
    </main>
        <div class="mb-2 fixed bottom-0 left-0 riht-0 w-full flex justify-center">
          <nav class="bg-background border border-primary rounded-lg flex items-center justify-center">
            <Button
              href="/admin"
              size="sm"
    variant="ghost"
            >
              Главная
            </Button>
            <Button
              href="/admin/products"
              size="sm"
    variant="ghost"
            >
              Товары
            </Button>
            <Button
              href="/admin/orders"
              size="sm"
    variant="ghost"
            >
            Заказы
            </Button>
            <Button
              href="/admin/categories"
              size="sm"
    variant="ghost"
            >
            Категории
            </Button>
          </nav>
        </div>

