{
	"name": "ansin",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "pnpm run lint-format-unsafe && astro dev",
		"build": "astro build",
		"deploy": "pnpm run lint-format-unsafe && ./scripts/deploy.sh",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check .",
		"lint-format": "biome check --write",
		"lint-format-unsafe": "biome check --write --unsafe .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:setup": "tsx scripts/setup-db.ts",
		"db:seed": "tsx scripts/seed-products.ts",
		"storage:test": "tsx scripts/test-storage.ts"
	},
	"dependencies": {
		"@astrojs/node": "^9.5.4",
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/s3-request-presigner": "^3.1000.0",
		"@libsql/client": "^0.17.0",
		"@tabler/icons": "^3",
		"@tailwindcss/forms": "^0.5",
		"@tailwindcss/vite": "^4",
		"astro": "^5.17.1",
		"better-auth": "^1.4.19",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"resend": "^6.9.2",
		"tailwind-merge": "^3",
		"tailwind-variants": "^3",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/node": "^25.3.0",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.9",
		"sharp": "^0.34.5",
		"tsx": "^4.21.0"
	}
}
