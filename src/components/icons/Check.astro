---
type Props = {
	class?: string;
	"aria-hidden"?: string | "true" | "false";
};

const { class: className, ...rest } = Astro.props;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	width="24"
	height="24"
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={className}
	{...rest}
>
	<path d="M5 12l5 5L20 7" />
</svg>
